---
// src/pages/servicios/[...slug].astro
export const prerender = false; // <--- MODO SERVIDOR (OBLIGATORIO PARA FIREBASE)

import { getCollection, render } from 'astro:content'; 
import MainLayout from '@/layouts/MainLayout.astro';
import { Image } from 'astro:assets';
import { getImage } from "astro:assets";

// COMPONENTES DE REACT
import CctvWizard from '@/modules/calculator/components/CctvWizard.jsx';
import ServiceGuard from '@/modules/calculator/components/ServiceGuard.jsx';

// LIBRERÍAS DE FIREBASE
import { db } from '@/lib/firebase/config';
import { collection, getDocs, doc, getDoc } from 'firebase/firestore'; // <--- Agregamos doc y getDoc

// ==================================================================
// 1. LÓGICA DE RECUPERACIÓN DE SERVICIO (ROUTING)
// ==================================================================
const { slug } = Astro.params;

// Obtenemos todos los servicios y buscamos el que coincida con la URL
const servicios = await getCollection('servicios');
const servicio = servicios.find((s: any) => s.slug === slug || s.id === slug);

// Si no existe el servicio, mandamos error 404
if (!servicio) {
  return Astro.redirect('/404');
}

const { Content } = await render(servicio);

// ==================================================================
// 2. RECUPERAR DATOS DE FIREBASE (BACKEND)
// ==================================================================

// A. TRAER PRODUCTOS (Cámaras) ☁️
let cloudProducts: any[] = [];
try {
  const querySnapshot = await getDocs(collection(db, "productos"));
  cloudProducts = querySnapshot.docs.map(doc => doc.data());
} catch (e) {
  console.error("Error conectando a productos:", e);
}

// B. TRAER CONFIGURACIÓN GLOBAL (Precios de instalación, cable, etc.) ⚙️
let globalConfig = { 
    manoObra: 80, 
    precioMetroCable: 2.5, 
    mensajeWhatsapp: "Hola, me interesa esta cotización:" 
}; // Valores por defecto por seguridad

try {
  const configRef = doc(db, "configuracion", "global");
  const configSnap = await getDoc(configRef);
  
  if (configSnap.exists()) {
    globalConfig = configSnap.data() as any;
  }
} catch (e) {
  console.error("Error cargando configuración:", e);
}

// ==================================================================
// 3. OPTIMIZACIÓN HÍBRIDA DE IMÁGENES (CLOUD DATA + LOCAL ASSETS)
// ==================================================================

// Mapa de todas las imágenes locales en la carpeta
const imageFiles = import.meta.glob('/src/assets/camaras/*.{jpeg,jpg,png,tiff,webp,gif,svg}');

// Cruzamos los datos de la nube con los archivos locales
const optimizedProducts = await Promise.all(
  cloudProducts.map(async (product) => {
    // Firebase nos da el nombre: "camara1.jpg"
    // Construimos la ruta local: "/src/assets/camaras/camara1.jpg"
    const imagePath = `/src/assets/camaras/${product.image}`;
    
    // Si la imagen no existe en la carpeta local, devolvemos el producto sin foto optimizada
    if (!imageFiles[imagePath]) {
      return product; 
    }

    // Si existe, Astro la procesa y optimiza a WebP
    const imageModule = await imageFiles[imagePath]() as any;
    const optimizedImage = await getImage({
      src: imageModule.default,
      format: 'webp',
      width: 600,
      quality: 80
    });

    // Devolvemos el producto con la URL optimizada
    return { ...product, image: optimizedImage.src };
  })
);
---

<MainLayout titulo={servicio.data.title} descripcion={servicio.data.description}>
  
  <article class="detalle-servicio">
    
    <header>
        <h1>{servicio.data.title}</h1>
        <p class="resumen">{servicio.data.description}</p>
    </header>

    {servicio.data.image && (
        <div class="imagen-principal">
            <Image src={servicio.data.image} alt={servicio.data.title} width={800} class="foto-redondeada" />
        </div>
    )}

    <div class="cuerpo-texto">
        <Content />
    </div>

    {/* ZONA DE HERRAMIENTAS SAAS */}
    {servicio.data.widget === 'cctv-wizard' && (
        <div class="zona-herramienta">
            <div class="header-herramienta">
                <h2>⚡ Cotizador Inteligente</h2>
                <p>Precios actualizados en tiempo real.</p>
            </div>
            
            <ServiceGuard client:only="react" toolId="cctv-wizard">
                {/* AQUÍ PASAMOS LOS DOS DATOS CLAVE:
                   1. products: La lista de cámaras.
                   2. config: Los precios de mano de obra y cable.
                */}
                <CctvWizard 
                    client:visible 
                    products={optimizedProducts} 
                    config={globalConfig} 
                />
            </ServiceGuard>
            
        </div>
    )}

    <div class="cta-box">
        <h3>¿Prefieres asistencia personalizada?</h3>
        <p>Si tienes dudas sobre la cotización o el servicio, un técnico te atenderá.</p>
        <a href={`https://wa.me/+51951413458?text=Consulta sobre ${servicio.data.title}`} class="btn-whatsapp" target="_blank">
            📲 Contactar por WhatsApp
        </a>
    </div>

  </article>

</MainLayout>

<style>
  .detalle-servicio { max-width: 800px; margin: 0 auto; background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 4px 10px rgba(0,0,0,0.05); }
  
  h1 { color: #0f172a; font-size: 2.2rem; margin-bottom: 10px; line-height: 1.2; }
  .resumen { font-size: 1.2rem; color: #64748b; margin-bottom: 2rem; border-left: 4px solid #fbbf24; padding-left: 15px; }
  
  .imagen-principal { margin-bottom: 2rem; }
  .foto-redondeada { border-radius: 12px; width: 100%; height: auto; object-fit: cover; }

  .cuerpo-texto { font-size: 1.1rem; line-height: 1.7; color: #334155; }
  .cuerpo-texto :global(h2) { color: #0f172a; margin-top: 2rem; border-bottom: 2px solid #f1f5f9; padding-bottom: 10px; }
  .cuerpo-texto :global(ul) { margin-bottom: 2rem; background: #f8fafc; padding: 20px 40px; border-radius: 8px; }
  .cuerpo-texto :global(strong) { color: #0f172a; }

  .zona-herramienta { margin-top: 3rem; margin-bottom: 3rem; border-top: 1px solid #e2e8f0; padding-top: 2rem; }
  .header-herramienta { text-align: center; margin-bottom: 2rem; }
  .header-herramienta h2 { font-size: 1.8rem; color: #2563eb; margin-bottom: 0.5rem; }
  .header-herramienta p { color: #64748b; }

  .cta-box { margin-top: 3rem; background: #0f172a; color: white; padding: 2rem; border-radius: 12px; text-align: center; }
  .btn-whatsapp { display: inline-block; background: #25D366; color: white; padding: 15px 30px; text-decoration: none; border-radius: 50px; font-weight: bold; margin-top: 15px; font-size: 1.1rem; transition: transform 0.2s; box-shadow: 0 4px 15px rgba(37, 211, 102, 0.4); }
  .btn-whatsapp:hover { transform: scale(1.05); }
</style>