---
// src/pages/servicios/index.astro
import MainLayout from '@/layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

// 1. Pedimos los datos
const servicios = await getCollection('servicios');
---

<MainLayout titulo="Nuestros Servicios" descripcion="Lista de servicios eléctricos profesionales en Arequipa.">

  <div class="header-servicios">
    <h1>Soluciones Eléctricas Profesionales</h1>
    <p>Atendemos emergencias y proyectos en todo Cerro Colorado y Arequipa.</p>
  </div>

  <div class="grid-servicios">
    
    {servicios.length === 0 && <p style="text-align: center">No hay servicios cargados aún.</p>}

    {servicios.map((servicio) => (
      /* CAMBIO CLAVE: 
         La tarjeta ahora es una etiqueta <a> (un enlace gigante).
         Esto hace que TODO sea clicable.
      */
      <a href={`/servicios/${servicio.id}`} class="tarjeta-servicio">
        
        {servicio.data.image && (
          <div class="img-container">
             <Image src={servicio.data.image} alt={servicio.data.title} width={400} />
          </div>
        )}

        <div class="contenido">
            <h3>{servicio.data.title}</h3>
            <p>{servicio.data.description}</p>
            
            {servicio.data.price && <p class="precio">💰 {servicio.data.price}</p>}
            
            {/* CAMBIO VISUAL: 
                Esto ya no es un <a href>, es un <span> visual.
                Parece botón, pero es parte del enlace padre.
            */}
            <span class="btn-ver">Ver Detalles →</span>
        </div>
      </a>
    ))}

  </div>

</MainLayout>

<style>
  .header-servicios { text-align: center; margin-bottom: 3rem; }
  h1 { color: #0f172a; font-size: 2.5rem; }

  .grid-servicios {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 30px;
  }

  /* ESTILOS DE LA TARJETA (Ahora aplicados al enlace <a>) */
  .tarjeta-servicio {
    display: block; /* Importante para que el enlace se comporte como caja */
    background: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 6px rgba(0,0,0,0.05);
    border: 1px solid #e2e8f0;
    transition: transform 0.2s, border-color 0.2s;
    text-decoration: none; /* Quitamos el subrayado azul feo de los enlaces */
    color: inherit; /* Hereda el color de texto normal */
  }
  
  /* Efecto Hover: Se levanta y cambia el borde a amarillo eléctrico */
  .tarjeta-servicio:hover { 
      transform: translateY(-5px); 
      border-color: #fbbf24; 
      box-shadow: 0 10px 15px rgba(0,0,0,0.1);
  }

  /* Efecto extra: Al pasar el mouse por la tarjeta, la imagen hace zoom suave */
  .img-container { height: 200px; overflow: hidden; }
  .img-container img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s;}
  .tarjeta-servicio:hover .img-container img { transform: scale(1.05); }

  .contenido { padding: 1.5rem; }
  h3 { margin-top: 0; color: #0f172a; font-size: 1.3rem; }
  
  /* Aseguramos que el texto descriptivo tenga color gris y no azul de link */
  .contenido p { color: #475569; }

  .precio { font-weight: bold; color: #16a34a; font-size: 1rem; margin-top: 10px;}
  
  /* Estilo del "Botón Falso" */
  .btn-ver {
    display: inline-block; margin-top: 15px; 
    background-color: #0f172a; color: white; padding: 10px 20px;
    border-radius: 6px; font-size: 0.9rem; font-weight: bold;
    transition: background 0.2s;
  }
  
  /* Al pasar el mouse sobre la tarjeta, el botón se pone azul técnico */
  .tarjeta-servicio:hover .btn-ver { background-color: #2563eb; }
</style>