---
// src/pages/servicios/[...slug].astro
export const prerender = false; // <--- MODO SERVIDOR (OBLIGATORIO PARA FIREBASE)

import { getCollection, render } from 'astro:content'; 
import MainLayout from '@/layouts/MainLayout.astro';
import { Image } from 'astro:assets';
import { getImage } from "astro:assets";

// LIBRERÍAS DE FIREBASE
import { db } from '@/lib/firebase/config';
import { collection, getDocs, doc, getDoc } from 'firebase/firestore';

// ==================================================================
// 1. LÓGICA DE RECUPERACIÓN DE SERVICIO (ROUTING)
// ==================================================================
const { slug } = Astro.params;

// Obtenemos todos los servicios y buscamos el que coincida con la URL
const servicios = await getCollection('servicios');
const servicio = servicios.find((s: any) => s.slug === slug || s.id === slug);

// Si no existe el servicio, mandamos error 404
if (!servicio) {
  return Astro.redirect('/404');
}

const { Content } = await render(servicio);

// ==================================================================
// 2. RECUPERAR DATOS DE FIREBASE (BACKEND)
// ==================================================================

// A. TRAER PRODUCTOS (Cámaras) ☁️
let cloudProducts: any[] = [];
try {
  const querySnapshot = await getDocs(collection(db, "productos"));
  cloudProducts = querySnapshot.docs.map(doc => doc.data());
} catch (e) {
  console.error("Error conectando a productos:", e);
}

// B. TRAER CONFIGURACIÓN GLOBAL ⚙️
let globalConfig = { 
    manoObra: 80, 
    precioMetroCable: 2.5, 
    mensajeWhatsapp: "Hola, me interesa esta cotización:" 
}; 

try {
  const configRef = doc(db, "configuracion", "global");
  const configSnap = await getDoc(configRef);
  
  if (configSnap.exists()) {
    globalConfig = configSnap.data() as any;
  }
} catch (e) {
  console.error("Error cargando configuración:", e);
}

// ==================================================================
// 3. OPTIMIZACIÓN HÍBRIDA DE IMÁGENES
// ==================================================================
const imageFiles = import.meta.glob('/src/assets/camaras/*.{jpeg,jpg,png,tiff,webp,gif,svg}');

const optimizedProducts = await Promise.all(
  cloudProducts.map(async (product) => {
    const imagePath = `/src/assets/camaras/${product.image}`;
    if (!imageFiles[imagePath]) {
      return product; 
    }
    const imageModule = await imageFiles[imagePath]() as any;
    const optimizedImage = await getImage({
      src: imageModule.default,
      format: 'webp',
      width: 600,
      quality: 80
    });
    return { ...product, image: optimizedImage.src };
  })
);
---

<MainLayout titulo={servicio.data.title} descripcion={servicio.data.description}>
  
  <article class="detalle-servicio">
    
    <header>
        <h1>{servicio.data.title}</h1>
        <p class="resumen">{servicio.data.description}</p>
    </header>

    {servicio.data.image && (
        <div class="imagen-principal">
            <Image src={servicio.data.image} alt={servicio.data.title} width={800} class="foto-redondeada" />
        </div>
    )}

    <div id="content-container" class="relative group">
        
        <div id="text-wrapper" class="prose max-w-none text-slate-700 mb-8 overflow-hidden max-h-[400px] md:max-h-none transition-all duration-500 ease-in-out">
            <Content />
        </div>

        <div id="fade-overlay" class="absolute bottom-0 left-0 w-full h-32 bg-gradient-to-t from-white to-transparent md:hidden pointer-events-none"></div>
    </div>

    <button id="toggle-btn" class="w-full md:hidden bg-slate-100 text-slate-700 font-bold py-3 rounded-lg border border-slate-200 mb-8 hover:bg-slate-200 transition-colors flex justify-center items-center gap-2 group">
        <span>⬇ Leer descripción completa</span>
    </button>

    <script is:inline>
        const btn = document.getElementById('toggle-btn');
        const wrapper = document.getElementById('text-wrapper');
        const overlay = document.getElementById('fade-overlay');
        let isExpanded = false;

        if(btn) {
            btn.addEventListener('click', () => {
                isExpanded = !isExpanded;
                
                if (isExpanded) {
                    wrapper.style.maxHeight = wrapper.scrollHeight + "px"; // Abrir
                    overlay.style.opacity = "0"; // Quitar sombra
                    btn.innerHTML = "⬆ Mostrar menos";
                    btn.classList.add('bg-blue-50', 'text-blue-600');
                } else {
                    wrapper.style.maxHeight = "400px"; // Cerrar
                    overlay.style.opacity = "1"; // Poner sombra
                    btn.innerHTML = "⬇ Leer descripción completa";
                    btn.classList.remove('bg-blue-50', 'text-blue-600');
                    wrapper.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            });
        }
    </script>

    {servicio.data.widget === 'cctv-wizard' && (
       <div class="bg-gradient-to-br from-slate-900 to-slate-800 rounded-2xl p-6 md:p-8 text-center text-white shadow-xl mb-12 relative overflow-hidden group border border-slate-700">
            <div class="absolute top-0 right-0 w-64 h-64 bg-blue-500 rounded-full mix-blend-multiply filter blur-3xl opacity-20 animate-blob"></div>
            <div class="absolute bottom-0 left-0 w-64 h-64 bg-purple-500 rounded-full mix-blend-multiply filter blur-3xl opacity-20 animate-blob animation-delay-2000"></div>

            <div class="relative z-10">
                <h3 class="text-2xl md:text-3xl font-bold mb-3 mt-2">¿Listo para diseñar tu sistema?</h3>
                <p class="text-slate-300 mb-6 max-w-lg mx-auto text-sm md:text-base">
                    Ya sabes cómo funciona. Ahora usa nuestro <strong>Asistente Inteligente</strong> y obtén tu precio exacto.
                </p>

                <a href="/cotizador" class="inline-flex items-center justify-center gap-2 bg-white text-slate-900 font-bold px-6 py-4 rounded-xl hover:scale-105 transition-transform shadow-lg hover:shadow-blue-500/25 w-full md:w-auto">
                    <span>🚀 Abrir Cotizador Inteligente</span>
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </a>
                
                <p class="mt-4 text-xs text-slate-500">Toma menos de 1 minuto • Sin compromiso</p>
            </div>
        </div>
    )}

    <div class="cta-box">
        <h3>¿Prefieres asistencia personalizada?</h3>
        <p>Si tienes dudas sobre la cotización o el servicio, un técnico te atenderá.</p>
        <a href={`https://wa.me/+51951413458?text=Consulta sobre ${servicio.data.title}`} class="btn-whatsapp" target="_blank">
            📲 Contactar por WhatsApp
        </a>
    </div>

  </article>

  <div class="fixed bottom-8 left-1/2 -translate-x-1/2 z-40 md:hidden w-max">
    <a href="/cotizador" 
       class="flex items-center gap-3 bg-slate-900 text-white px-6 py-3 rounded-full shadow-xl shadow-blue-900/40 border border-blue-500/30 backdrop-blur-md font-bold text-sm animate-pulse-slow">
      
      <span class="bg-blue-600 p-1 rounded-full flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
      </span>
      
      <span>Cotizar Ahora</span>
    </a>
  </div>

</MainLayout>

<style>
  .detalle-servicio { max-width: 800px; margin: 0 auto; background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 4px 10px rgba(0,0,0,0.05); }
  
  h1 { color: #0f172a; font-size: 2.2rem; margin-bottom: 10px; line-height: 1.2; }
  .resumen { font-size: 1.2rem; color: #64748b; margin-bottom: 2rem; border-left: 4px solid #fbbf24; padding-left: 15px; }
  
  .imagen-principal { margin-bottom: 2rem; }
  .foto-redondeada { border-radius: 12px; width: 100%; height: auto; object-fit: cover; }

  /* Estilos para el Markdown */
  .cuerpo-texto { font-size: 1.1rem; line-height: 1.7; color: #334155; }
  .cuerpo-texto :global(h2) { color: #0f172a; margin-top: 2rem; border-bottom: 2px solid #f1f5f9; padding-bottom: 10px; font-weight: bold; }
  .cuerpo-texto :global(h3) { color: #1e293b; margin-top: 1.5rem; font-weight: bold; }
  .cuerpo-texto :global(ul) { margin-bottom: 2rem; background: #f8fafc; padding: 20px 40px; border-radius: 8px; list-style-type: disc; }
  .cuerpo-texto :global(li) { margin-bottom: 0.5rem; }
  .cuerpo-texto :global(strong) { color: #0f172a; font-weight: 700; }

  .cta-box { margin-top: 3rem; background: #0f172a; color: white; padding: 2rem; border-radius: 12px; text-align: center; }
  .btn-whatsapp { display: inline-block; background: #25D366; color: white; padding: 15px 30px; text-decoration: none; border-radius: 50px; font-weight: bold; margin-top: 15px; font-size: 1.1rem; transition: transform 0.2s; box-shadow: 0 4px 15px rgba(37, 211, 102, 0.4); }
  .btn-whatsapp:hover { transform: scale(1.05); }

  /* Animación suave para el fondo de la tarjeta */
  @keyframes blob {
    0% { transform: translate(0px, 0px) scale(1); }
    33% { transform: translate(30px, -50px) scale(1.1); }
    66% { transform: translate(-20px, 20px) scale(0.9); }
    100% { transform: translate(0px, 0px) scale(1); }
  }
  .animate-blob {
    animation: blob 7s infinite;
  }
  .animation-delay-2000 {
    animation-delay: 2s;
  }

  /* Animación sutil para llamar la atención sin ser molesta */
  @keyframes pulse-slow {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.05); }
  }
  .animate-pulse-slow {
    animation: pulse-slow 3s infinite ease-in-out;
  }
</style>