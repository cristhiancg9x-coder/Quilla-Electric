---
// src/pages/cotizador.astro

// 1. IMPORTANTE: Desactivamos el prerenderizado para que funcione dinámico en el servidor (Vercel)
export const prerender = false;

import MainLayout from '@/layouts/MainLayout.astro';
import CctvWizard from '@/modules/calculator/components/CctvWizard.jsx';

// 2. Importamos la base de datos cruda
import productsData from '@/modules/calculator/data/cctv-products.json';

// 3. Importamos la herramienta de optimización de Astro
import { getImage } from "astro:assets";

// 4. Cargamos TODAS las imágenes de la carpeta assets (Mapeo automático)
const imageFiles = import.meta.glob('/src/assets/camaras/*.{jpeg,jpg,png,tiff,webp,gif,svg}');

// 5. PROCESO DE AUTOMATIZACIÓN (Esto ocurre en milisegundos al construir)
const optimizedProducts = await Promise.all(
  productsData.map(async (product) => {
    // Construimos la ruta donde debería estar la imagen
    const imagePath = `/src/assets/camaras/${product.image}`;
    
    // Verificamos si la imagen existe en la carpeta
    if (!imageFiles[imagePath]) {
      console.error(`⚠️ Alerta: No encontré la imagen ${product.image} en src/assets/camaras`);
      return product; // Si no existe, devolvemos el producto sin cambios
    }

    // Si existe, la procesamos
    const imageModule = await imageFiles[imagePath]() as any;
    const optimizedImage = await getImage({
      src: imageModule.default,
      format: 'webp', // ¡Conversión automática!
      width: 600,     // Redimensionado automático
      quality: 80     // Compresión inteligente
    });

    // Devolvemos el producto con la NUEVA ruta optimizada
    return {
      ...product,
      image: optimizedImage.src 
    };
  })
);
---

<MainLayout title="Configurador CCTV | Quilla Electric" description="Diseña tu propio sistema de seguridad en 3 pasos.">
  
  <section class="min-h-screen bg-slate-950 flex flex-col items-center justify-start pt-24 pb-12 px-4 md:pt-32">
    
    <div class="text-center mb-8 md:mb-10 max-w-2xl mx-auto animate-fade-in-down">
      
      <span class="inline-block py-1 px-3 rounded-full bg-blue-900/30 border border-blue-500/30 text-blue-400 text-xs font-bold tracking-wider mb-4 uppercase">
        Configurador Online
      </span>

      <h1 class="text-3xl md:text-5xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-indigo-400 to-purple-500 mb-4 leading-tight">
        Diseña tu Sistema
      </h1>
      
      <p class="text-slate-400 text-sm md:text-lg max-w-lg mx-auto">
        Responde 3 preguntas y obtén un presupuesto detallado con instalación incluida.
      </p>
    </div>

    <div class="w-full max-w-5xl">
      <CctvWizard 
        client:load 
        products={optimizedProducts} 
        config={{}} 
      />
    </div>

  </section>

</MainLayout>

<style>
  /* Animación suave de entrada para el título */
  .animate-fade-in-down {
    animation: fadeInDown 0.8s ease-out forwards;
  }

  @keyframes fadeInDown {
    from {
      opacity: 0;
      transform: translateY(-20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>