---
// src/pages/cotizador.astro

// 1. MODO SERVIDOR: Obligatorio para leer precios frescos de Firebase
export const prerender = false;

import MainLayout from '@/layouts/MainLayout.astro';
import CctvWizard from '@/modules/calculator/components/CctvWizard.jsx';

// Importamos herramientas de Astro y Firebase
import { getImage } from "astro:assets";
import { db } from '@/lib/firebase/config';
import { collection, getDocs, doc, getDoc } from 'firebase/firestore';

// ---------------------------------------------------------
// 1. RECUPERAR PRODUCTOS (Cámaras, NVRs - Venta)
// ---------------------------------------------------------
let cloudProducts = [];
try {
  const querySnapshot = await getDocs(collection(db, "productos"));
  cloudProducts = querySnapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
} catch (error) {
  console.error("❌ Error leyendo productos:", error);
}

// ---------------------------------------------------------
// 2. RECUPERAR INSUMOS (Tubos, Cables - Materiales) 🔥 NUEVO
// ---------------------------------------------------------
let cloudSupplies = [];
try {
  const suppliesSnap = await getDocs(collection(db, "insumos"));
  cloudSupplies = suppliesSnap.docs.map(doc => ({ id: doc.id, ...doc.data() }));
} catch (error) {
  console.error("❌ Error leyendo insumos:", error);
}

// ---------------------------------------------------------
// 3. RECUPERAR PRECIOS GLOBALES (Configuración)
// ---------------------------------------------------------
let globalConfig = {
  manoObra: 120,          
  precioMetroCable: 2.5,  
  mensajeWhatsapp: "Hola, quiero cotizar este sistema:"
};

try {
  const configRef = doc(db, "configuracion", "global");
  const configSnap = await getDoc(configRef);

  if (configSnap.exists()) {
    globalConfig = { ...globalConfig, ...configSnap.data() };
  }
} catch (error) {
  console.error("❌ Error leyendo configuración:", error);
}

// ---------------------------------------------------------
// 4. PROCESAMIENTO DE IMÁGENES (Optimización)
// ---------------------------------------------------------
const imageFiles = import.meta.glob('/src/assets/camaras/*.{jpeg,jpg,png,tiff,webp,gif,svg}');

const optimizedProducts = await Promise.all(
  cloudProducts.map(async (product) => {
    // Si es URL externa (ej. Firebase Storage), la dejamos pasar
    if (product.image && product.image.startsWith('http')) {
        return product;
    }

    // Si es local, la optimizamos
    const imagePath = `/src/assets/camaras/${product.image}`;
    if (!imageFiles[imagePath]) {
      return product;
    }
    
    const imageModule = await imageFiles[imagePath]();
    const optimizedImage = await getImage({
      src: imageModule.default,
      format: 'webp',
      width: 600,
      quality: 80
    });
    return { ...product, image: optimizedImage.src };
  })
);
---

<MainLayout title="Configurador CCTV | Quilla Electric" description="Diseña tu propio sistema de seguridad en 3 pasos.">
  
  <section class="min-h-screen bg-slate-950 flex flex-col items-center justify-start pt-24 pb-12 px-4 md:pt-32">
    
    <div class="text-center mb-8 md:mb-10 max-w-2xl mx-auto animate-fade-in-down">
      <span class="inline-block py-1 px-3 rounded-full bg-blue-900/30 border border-blue-500/30 text-blue-400 text-xs font-bold tracking-wider mb-4 uppercase">
        Configurador Online
      </span>

      <h1 class="text-3xl md:text-5xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-indigo-400 to-purple-500 mb-4 leading-tight">
        Diseña tu Sistema
      </h1>
      
      <p class="text-slate-400 text-sm md:text-lg max-w-lg mx-auto">
        Precios actualizados en tiempo real. Responde 3 preguntas y obtén tu presupuesto.
      </p>
    </div>

    <div class="w-full max-w-5xl">
      <CctvWizard 
        client:load 
        products={optimizedProducts} 
        supplies={cloudSupplies} 
        config={globalConfig} 
      />
    </div>

  </section>

</MainLayout>

<style>
  .animate-fade-in-down {
    animation: fadeInDown 0.8s ease-out forwards;
  }
  @keyframes fadeInDown {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>