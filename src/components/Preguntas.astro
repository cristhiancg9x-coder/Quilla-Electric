---
// src/components/Preguntas.astro

const preguntas = [
  {
    pregunta: "¿Cuánto cuesta el mantenimiento de un Pozo a Tierra?",
    respuesta: "El precio base incluye la limpieza, reactivación con gel y certificado. El costo exacto depende del estado actual del pozo. ¡Escríbenos para una visita técnica gratuita!"
  },
  {
    pregunta: "¿Atienden emergencias los domingos?",
    respuesta: "Sí, tenemos un equipo de guardia para emergencias eléctricas las 24 horas, incluyendo domingos y feriados en todo Arequipa."
  },
  {
    pregunta: "¿Entregan certificado para Defensa Civil?",
    respuesta: "Sí. Realizamos el protocolo de pruebas completo y entregamos el certificado de operatividad firmado por un Ingeniero Electricista colegiado y habilitado."
  },
  {
    pregunta: "¿Mis cables están muy viejos, es peligroso?",
    respuesta: "Si tus cables tienen más de 20 años o son tipo 'mellizo' (blancos planos), son un riesgo de incendio. Recomendamos una inspección para cambiarlos por cables libres de halógenos."
  }
];

const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": preguntas.map(item => ({
    "@type": "Question",
    "name": item.pregunta,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.respuesta
    }
  }))
};
---

<script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />

<section class="faq-section relative">
  <div class="absolute top-1/2 left-0 -translate-y-1/2 w-[300px] h-[300px] bg-purple-600/10 blur-[80px] rounded-full -z-10 pointer-events-none"></div>

  <h2 class="titulo-faq">Preguntas Frecuentes</h2>
  
  <div class="faq-container">
    
    {preguntas.map((item) => (
      <details class="group">
        <summary class="glass-panel">
            <span>{item.pregunta}</span>
            <span class="icon">+</span>
        </summary>
        <div class="respuesta-content">
            <p>{item.respuesta}</p>
        </div>
      </details>
    ))}

  </div>
</section>

<style>
  .faq-section { margin-top: 6rem; margin-bottom: 6rem; padding: 0 1rem; position: relative; }
  
  .titulo-faq { 
    text-align: center; 
    margin-bottom: 3rem; 
    color: #334155; /* Un tono oscuro para contrastar si el fondo es claro, o blanco si es oscuro */
    /* Ajuste para fondo oscuro: */
    color: rgba(255,255,255,0.1);
    font-size: 3rem; 
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 2px;
    /* Truco: Texto transparente con borde (Outline text) */
    -webkit-text-stroke: 1px rgba(255,255,255,0.2);
  }

  /* Si prefieres el título sólido blanco brillante, usa este bloque en su lugar: */
  .titulo-faq {
      color: white;
      -webkit-text-stroke: 0;
      text-shadow: 0 0 20px rgba(255, 255, 255, 0.2);
  }

  .faq-container { max-width: 800px; margin: 0 auto; display: flex; flex-direction: column; gap: 16px; }

  /* ESTILO CRISTAL (Glassmorphism) */
  details {
    overflow: hidden; /* Para la animación */
  }

  summary {
    background: rgba(255, 255, 255, 0.03); /* Casi transparente */
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 20px 24px;
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.3s ease;
    
    font-weight: 600;
    color: white;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 1.1rem;
  }
  
  /* Hover: Brillo dorado */
  summary:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 215, 0, 0.5); /* Dorado sutil */
  }

  /* Estado Abierto */
  details[open] summary {
    background: linear-gradient(90deg, rgba(255, 215, 0, 0.1), transparent);
    border-color: #ffd700;
    color: #ffd700;
  }

  .icon { 
    font-size: 1.5rem; 
    color: #00f0ff; /* Cian */
    transition: transform 0.3s; 
  }
  
  details[open] .icon { 
    transform: rotate(45deg); 
    color: #ffd700; /* Cambia a dorado al abrir */
  }

  /* Respuesta */
  .respuesta-content {
    padding: 20px 24px;
    color: #cbd5e1; /* Gris claro */
    line-height: 1.7;
    border-left: 1px solid rgba(255, 255, 255, 0.1);
    margin-left: 12px; /* Indentación elegante */
    animation: slideDown 0.3s ease-out;
  }

  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>