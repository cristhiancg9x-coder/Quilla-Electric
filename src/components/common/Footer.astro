---
// src/components/common/Footer.astro
const currentYear = new Date().getFullYear();
---

<footer class="footer-electrico relative overflow-hidden">
  
  <div class="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-cyan-500 to-transparent opacity-70"></div>
  
  <div class="absolute bottom-0 right-0 w-[300px] h-[300px] bg-blue-900/10 blur-[100px] rounded-full -z-10 pointer-events-none"></div>

  <div class="contenedor-footer">
    
    <div class="columna brand-col">
      <h3 class="flex items-center gap-2 text-2xl font-extrabold text-white mb-4">
        <span class="text-cyan-400 text-3xl">⚡</span> 
        Quilla<span class="text-cyan-400">Electric</span>
      </h3>
      <p class="text-slate-400 text-sm leading-relaxed mb-6">
        Soluciones eléctricas seguras y certificadas para hogares y empresas en Arequipa. Tecnología y seguridad en cada conexión.
      </p>
      <p class="copyright text-slate-600 text-xs">
        © {currentYear} Quilla Electric. <br>Todos los derechos reservados.
      </p>
    </div>

    <div class="columna">
      <h4 class="text-white font-bold mb-6 border-l-4 border-cyan-500 pl-3 uppercase tracking-wider text-sm">Navegación</h4>
      <ul class="space-y-2">
        <li><a href="/" class="footer-link">Inicio</a></li>
        <li><a href="/servicios" class="footer-link">Servicios</a></li>
        <li><a href="/blog" class="footer-link">Blog & Noticias</a></li>
        <li><a href="/contacto" class="footer-link">Contacto</a></li>
      </ul>
    </div>

    <div class="columna">
      <h4 class="text-white font-bold mb-6 border-l-4 border-purple-500 pl-3 uppercase tracking-wider text-sm">Cobertura</h4>
      <ul class="space-y-2">
        <li><a href="/electricista-en/cerro-colorado" class="footer-link">Cerro Colorado</a></li>
        <li><a href="/electricista-en/cayma" class="footer-link">Cayma</a></li>
        <li><a href="/electricista-en/yanahuara" class="footer-link">Yanahuara</a></li>
        <li><a href="/electricista-en/jlbyr" class="footer-link">J.L.B. y Rivero</a></li>
        <li><a href="/electricista-en/arequipa-cercado" class="footer-link">Cercado</a></li>
      </ul>
    </div>

    <div class="columna">
      <h4 class="text-white font-bold mb-6 border-l-4 border-green-500 pl-3 uppercase tracking-wider text-sm">Contacto</h4>
      <ul class="space-y-4 text-sm text-slate-400">
        <li class="flex items-start gap-3">
          <span class="text-cyan-400 mt-1">📍</span>
          <span>Cerro Colorado, Arequipa</span>
        </li>
        <li class="flex items-center gap-3">
          <span class="text-cyan-400">📞</span>
          <a href="tel:951413458" class="hover:text-white transition-colors">951413458</a>
        </li>
        <li class="flex items-center gap-3">
          <span class="text-cyan-400">📧</span>
          <a href="mailto:quillaelectriccyt@gmail.com" class="hover:text-white transition-colors break-all">quillaelectriccyt@gmail.com</a>
        </li>
      </ul>

      <div class="redes mt-6 flex gap-4">
        <a href="https://facebook.com" target="_blank" aria-label="Facebook" class="social-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/></svg>
        </a>

        <a href="https://wa.me/51951413458" target="_blank" aria-label="WhatsApp" class="social-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
        </a>
      </div>

    </div>

  </div>
</footer>

<style>
  .footer-electrico {
    background: linear-gradient(to bottom, #050b14, #02060a);
    color: #cbd5e1;
    padding: 4rem 1.5rem;
    margin-top: auto;
  }

  .contenedor-footer {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 40px;
  }

  /* Enlaces estilizados */
  .footer-link {
    color: #94a3b8;
    text-decoration: none;
    transition: all 0.3s ease;
    display: inline-block;
    font-size: 0.95rem;
  }

  .footer-link:hover {
    color: #00f0ff; /* Cian eléctrico */
    transform: translateX(5px); /* Desplazamiento sutil */
    text-shadow: 0 0 8px rgba(0, 240, 255, 0.4);
  }

  /* Iconos sociales de cristal */
  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 50%; /* Círculo perfecto */
    color: #cbd5e1;
    transition: all 0.3s ease;
  }

  .social-icon:hover {
    background: #00f0ff;
    color: #050b14; /* Icono oscuro sobre fondo brillante */
    box-shadow: 0 0 15px rgba(0, 240, 255, 0.6);
    transform: translateY(-3px);
  }
</style>